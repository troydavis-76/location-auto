<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AutoLoc Havre — Location de Véhicules</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0A0A0A;
    --white: #F8F8F6;
    --gray-100: #F0EFEC;
    --gray-300: #C8C7C2;
    --gray-500: #7A7975;
    --gray-700: #3A3935;
    --accent: #E8E0D0;
    --red: #D04030;
    --shadow: rgba(10,10,10,0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--white);
    color: var(--black);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── DEMO BADGE ── */
  .demo-badge {
    position: fixed;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--red);
    color: #fff;
    padding: 6px 18px;
    border-radius: 20px;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    z-index: 9999;
    box-shadow: 0 4px 16px rgba(208,64,48,0.35);
    animation: fadeDown 0.5s ease;
    white-space: nowrap;
  }
  @keyframes fadeDown {
    from { opacity: 0; transform: translateX(-50%) translateY(-10px); }
    to { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* ── HEADER ── */
  header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 20px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(248,248,246,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(10,10,10,0.08);
  }
  .logo {
    font-family: 'Syne', sans-serif;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--black);
  }
  .logo span { color: var(--red); }
  nav { display: flex; gap: 32px; align-items: center; }
  nav a {
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--gray-500);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  nav a:hover { color: var(--black); }
  .nav-cta {
    background: var(--black);
    color: var(--white) !important;
    padding: 9px 20px;
    border-radius: 3px;
    font-weight: 500 !important;
    letter-spacing: 0.02em !important;
    text-transform: none !important;
    transition: background 0.2s !important;
  }
  .nav-cta:hover { background: var(--gray-700) !important; color: var(--white) !important; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    padding: 120px 48px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    right: -100px; top: 50%;
    transform: translateY(-50%);
    width: 600px; height: 600px;
    border-radius: 50%;
    background: var(--gray-100);
    z-index: 0;
  }
  .hero-content { position: relative; z-index: 1; }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 28px;
    font-weight: 500;
  }
  .hero-tag::before {
    content: '';
    width: 24px; height: 1px;
    background: var(--red);
  }
  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3rem, 5.5vw, 5rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
    color: var(--black);
  }
  .hero h1 em {
    font-style: normal;
    color: var(--red);
  }
  .hero p {
    font-size: 1rem;
    color: var(--gray-500);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 40px;
    font-weight: 300;
  }
  .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary {
    background: var(--black);
    color: var(--white);
    border: none;
    padding: 14px 32px;
    border-radius: 3px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    letter-spacing: 0.01em;
  }
  .btn-primary:hover { background: var(--gray-700); transform: translateY(-1px); }
  .btn-outline {
    background: transparent;
    color: var(--black);
    border: 1.5px solid var(--black);
    padding: 14px 32px;
    border-radius: 3px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-outline:hover { background: var(--black); color: var(--white); }

  .hero-visual {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .stat-card {
    background: var(--black);
    color: var(--white);
    padding: 24px;
    border-radius: 8px;
  }
  .stat-card:nth-child(2) { background: var(--gray-100); color: var(--black); margin-top: 24px; }
  .stat-card:nth-child(3) { background: var(--gray-100); color: var(--black); margin-top: -24px; }
  .stat-card:nth-child(4) { background: var(--red); color: var(--white); }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-label { font-size: 0.78rem; opacity: 0.7; font-weight: 300; }

  /* ── INFO BAR ── */
  .info-bar {
    background: var(--black);
    padding: 18px 48px;
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
    align-items: center;
  }
  .info-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: var(--gray-300);
    font-weight: 300;
  }
  .info-item .icon { font-size: 1rem; }

  /* ── FLEET SECTION ── */
  .section {
    padding: 80px 48px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
  }
  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 10px;
    font-weight: 500;
  }
  .section h2 {
    font-family: 'Syne', sans-serif;
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .fleet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2px;
    background: var(--black);
    border: 2px solid var(--black);
    border-radius: 8px;
    overflow: hidden;
  }
  .vehicle-card {
    background: var(--white);
    padding: 32px;
    transition: background 0.25s;
    cursor: default;
    position: relative;
  }
  .vehicle-card:hover { background: var(--gray-100); }
  .vehicle-type {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: 12px;
    font-weight: 500;
  }
  .vehicle-name {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .vehicle-desc {
    font-size: 0.83rem;
    color: var(--gray-500);
    line-height: 1.6;
    margin-bottom: 20px;
    font-weight: 300;
  }
  .vehicle-features {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .feature-tag {
    font-size: 0.72rem;
    background: var(--gray-100);
    color: var(--gray-700);
    padding: 4px 10px;
    border-radius: 2px;
    font-weight: 400;
  }
  .vehicle-price {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 16px;
    border-top: 1px solid var(--gray-100);
  }
  .price-amount {
    font-family: 'Syne', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
  }
  .price-unit { font-size: 0.75rem; color: var(--gray-500); }
  .vehicle-emoji {
    font-size: 2.8rem;
    position: absolute;
    top: 28px;
    right: 28px;
    opacity: 0.15;
  }

  /* ── PROCESS ── */
  .process-section {
    background: var(--black);
    padding: 80px 48px;
    color: var(--white);
  }
  .process-inner { max-width: 1200px; margin: 0 auto; }
  .process-section .section-label { color: var(--gray-300); }
  .process-section h2 { color: var(--white); }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 48px;
    background: var(--gray-700);
    border: 2px solid var(--gray-700);
    border-radius: 8px;
    overflow: hidden;
  }
  .step {
    background: var(--black);
    padding: 32px 28px;
    position: relative;
  }
  .step-num {
    font-family: 'Syne', sans-serif;
    font-size: 3rem;
    font-weight: 800;
    color: var(--gray-700);
    line-height: 1;
    margin-bottom: 16px;
  }
  .step h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--white);
  }
  .step p { font-size: 0.82rem; color: var(--gray-500); line-height: 1.6; font-weight: 300; }

  /* ── FOOTER ── */
  footer {
    background: var(--black);
    color: var(--gray-500);
    padding: 28px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    border-top: 1px solid var(--gray-700);
  }
  footer .logo { font-size: 1rem; color: var(--white); }

  /* ── CHAT WIDGET ── */
  #chat-widget {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  #chat-box {
    width: 368px;
    height: 530px;
    background: var(--white);
    border-radius: 12px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.22), 0 4px 16px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px) scale(0.96);
    pointer-events: none;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 1.5px solid rgba(10,10,10,0.1);
  }
  #chat-box.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  .chat-header {
    background: var(--black);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .chat-avatar {
    width: 36px; height: 36px;
    background: var(--red);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
    font-weight: 700;
    color: var(--white);
    font-family: 'Syne', sans-serif;
  }
  .chat-header-info { flex: 1; }
  .chat-header-name { color: var(--white); font-weight: 500; font-size: 0.88rem; }
  .chat-header-status { color: var(--gray-500); font-size: 0.72rem; display: flex; align-items: center; gap: 5px; margin-top: 2px; }
  .dot-online { width: 6px; height: 6px; background: #5CB85C; border-radius: 50%; }
  .chat-close {
    background: none; border: none; color: var(--gray-500); font-size: 1.1rem; cursor: pointer;
    width: 28px; height: 28px; border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, color 0.2s;
  }
  .chat-close:hover { background: rgba(255,255,255,0.1); color: var(--white); }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 18px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
    background: var(--gray-100);
  }
  .chat-messages::-webkit-scrollbar { width: 3px; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--gray-300); border-radius: 2px; }

  .msg {
    display: flex;
    gap: 8px;
    animation: msgIn 0.25s ease;
  }
  @keyframes msgIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .msg.user { flex-direction: row-reverse; }
  .msg-avatar-sm {
    width: 26px; height: 26px;
    border-radius: 4px;
    background: var(--red);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem; color: var(--white); font-weight: 700;
    flex-shrink: 0; align-self: flex-end;
    font-family: 'Syne', sans-serif;
  }
  .msg.user .msg-avatar-sm { background: var(--gray-700); }
  .msg-bubble {
    max-width: 78%;
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 0.84rem;
    line-height: 1.55;
    font-weight: 300;
  }
  .msg.bot .msg-bubble {
    background: var(--white);
    color: var(--black);
    border-bottom-left-radius: 2px;
    box-shadow: 0 1px 4px var(--shadow);
  }
  .msg.user .msg-bubble {
    background: var(--black);
    color: var(--white);
    border-bottom-right-radius: 2px;
  }

  .typing-indicator {
    display: flex; gap: 4px; padding: 12px 14px;
    background: var(--white); border-radius: 10px; border-bottom-left-radius: 2px;
    box-shadow: 0 1px 4px var(--shadow);
    width: fit-content;
  }
  .typing-indicator span {
    width: 6px; height: 6px;
    background: var(--gray-300); border-radius: 50%;
    animation: bounce 1.2s infinite;
  }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-5px); background: var(--black); }
  }

  .quick-replies {
    padding: 10px 14px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    background: var(--white);
    border-top: 1px solid var(--gray-100);
  }
  .quick-reply {
    background: var(--white);
    border: 1.5px solid var(--black);
    color: var(--black);
    padding: 5px 12px;
    border-radius: 3px;
    font-size: 0.75rem;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .quick-reply:hover { background: var(--black); color: var(--white); }

  .chat-input-area {
    padding: 12px 14px;
    border-top: 1px solid var(--gray-100);
    display: flex;
    gap: 8px;
    align-items: center;
    background: var(--white);
  }
  #chat-input {
    flex: 1;
    border: 1.5px solid var(--gray-100);
    border-radius: 6px;
    padding: 9px 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.84rem;
    outline: none;
    background: var(--gray-100);
    transition: border-color 0.2s;
    color: var(--black);
  }
  #chat-input:focus { border-color: var(--black); background: var(--white); }
  #chat-send {
    width: 36px; height: 36px;
    background: var(--black);
    border: none;
    border-radius: 6px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: var(--white);
    font-size: 0.9rem;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  #chat-send:hover { background: var(--gray-700); }

  #chat-toggle {
    width: 56px; height: 56px;
    background: var(--black);
    border: none;
    border-radius: 10px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    box-shadow: 0 8px 28px rgba(0,0,0,0.28);
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }
  #chat-toggle:hover { transform: scale(1.06); box-shadow: 0 12px 36px rgba(0,0,0,0.35); }
  #chat-toggle .notif {
    position: absolute;
    top: -4px; right: -4px;
    width: 14px; height: 14px;
    background: var(--red);
    border-radius: 50%;
    border: 2px solid var(--white);
    animation: pulse 2s infinite;
    display: none;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.3); }
  }

  @media (max-width: 768px) {
    header { padding: 16px 20px; }
    nav { display: none; }
    .hero { grid-template-columns: 1fr; padding: 100px 20px 60px; gap: 40px; }
    .hero::before { display: none; }
    .info-bar { padding: 14px 20px; gap: 20px; }
    .section { padding: 60px 20px; }
    .steps-grid { grid-template-columns: 1fr 1fr; }
    footer { flex-direction: column; gap: 12px; text-align: center; padding: 24px 20px; }
    #chat-box { width: calc(100vw - 40px); }
  }
</style>
</head>
<body>

<div class="demo-badge">🎯 DÉMO — Site + Chatbot IA pour location de véhicules</div>

<header>
  <div class="logo">Auto<span>Loc</span> Havre</div>
  <nav>
    <a href="#">Flotte</a>
    <a href="#">Tarifs</a>
    <a href="#">Contact</a>
    <a href="#" class="nav-cta">Réserver</a>
  </nav>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-tag">Location de véhicules — Le Havre</div>
    <h1>Roulez<br>sans<br><em>contraintes</em></h1>
    <p>Véhicules compacts et 9 places disponibles à Le Havre. Location courte ou longue durée, tarifs transparents, disponibilité immédiate.</p>
    <div class="hero-btns">
      <button class="btn-primary">Voir la flotte</button>
      <button class="btn-outline" onclick="toggleChat()">💬 Poser une question</button>
    </div>
  </div>
  <div class="hero-visual">
    <div class="hero-stats">
      <div class="stat-card">
        <div class="stat-num">5+</div>
        <div class="stat-label">Véhicules disponibles</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">24h</div>
        <div class="stat-label">Location possible dès</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">9</div>
        <div class="stat-label">Places max par véhicule</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">100%</div>
        <div class="stat-label">Satisfaction client</div>
      </div>
    </div>
  </div>
</section>

<!-- INFO BAR -->
<div class="info-bar">
  <div class="info-item"><span class="icon">📍</span> Le Havre, Seine-Maritime</div>
  <div class="info-item"><span class="icon">🕐</span> Lun–Sam : 8h–19h</div>
  <div class="info-item"><span class="icon">📞</span> 02 35 XX XX XX</div>
  <div class="info-item"><span class="icon">✅</span> Courte & longue durée</div>
</div>

<!-- FLEET -->
<div class="section">
  <div class="section-header">
    <div>
      <div class="section-label">Notre flotte</div>
      <h2>Véhicules<br>disponibles</h2>
    </div>
  </div>
  <div class="fleet-grid">
    <div class="vehicle-card">
      <div class="vehicle-emoji">🚗</div>
      <div class="vehicle-type">Citadine</div>
      <div class="vehicle-name">Véhicule Compact</div>
      <div class="vehicle-desc">Idéal pour les déplacements en ville et les courts trajets. Économique et facile à garer.</div>
      <div class="vehicle-features">
        <span class="feature-tag">5 places</span>
        <span class="feature-tag">Climatisation</span>
        <span class="feature-tag">GPS</span>
      </div>
      <div class="vehicle-price">
        <div>
          <div class="price-amount">35€</div>
          <div class="price-unit">par jour</div>
        </div>
        <button class="btn-primary" style="padding:9px 18px;font-size:0.82rem;">Réserver</button>
      </div>
    </div>
    <div class="vehicle-card">
      <div class="vehicle-emoji">🚐</div>
      <div class="vehicle-type">Minibus</div>
      <div class="vehicle-name">9 Places</div>
      <div class="vehicle-desc">Parfait pour les groupes, transferts aéroport, sorties familiales ou déplacements professionnels.</div>
      <div class="vehicle-features">
        <span class="feature-tag">9 places</span>
        <span class="feature-tag">Grand coffre</span>
        <span class="feature-tag">Climatisation</span>
      </div>
      <div class="vehicle-price">
        <div>
          <div class="price-amount">75€</div>
          <div class="price-unit">par jour</div>
        </div>
        <button class="btn-primary" style="padding:9px 18px;font-size:0.82rem;">Réserver</button>
      </div>
    </div>
    <div class="vehicle-card">
      <div class="vehicle-emoji">📦</div>
      <div class="vehicle-type">Longue durée</div>
      <div class="vehicle-name">Tarif Semaine</div>
      <div class="vehicle-desc">Besoin d'un véhicule pour plusieurs jours ? Profitez de nos tarifs dégressifs sur la semaine ou le mois.</div>
      <div class="vehicle-features">
        <span class="feature-tag">-20% / semaine</span>
        <span class="feature-tag">-30% / mois</span>
        <span class="feature-tag">Kilométrage illimité</span>
      </div>
      <div class="vehicle-price">
        <div>
          <div class="price-amount">Sur devis</div>
          <div class="price-unit">selon durée</div>
        </div>
        <button class="btn-outline" style="padding:9px 18px;font-size:0.82rem;" onclick="toggleChat()">Demander</button>
      </div>
    </div>
  </div>
</div>

<!-- PROCESS -->
<div class="process-section">
  <div class="process-inner">
    <div class="section-label">Comment ça marche</div>
    <h2 style="color:var(--white);">Louer en<br>4 étapes</h2>
    <div class="steps-grid">
      <div class="step">
        <div class="step-num">01</div>
        <h3>Choisissez</h3>
        <p>Sélectionnez le véhicule adapté à votre besoin et vos dates de location.</p>
      </div>
      <div class="step">
        <div class="step-num">02</div>
        <h3>Contactez</h3>
        <p>Appelez-nous ou utilisez le chatbot pour vérifier la disponibilité en temps réel.</p>
      </div>
      <div class="step">
        <div class="step-num">03</div>
        <h3>Confirmez</h3>
        <p>Réservation confirmée par téléphone. Pièce d'identité et permis de conduire requis.</p>
      </div>
      <div class="step">
        <div class="step-num">04</div>
        <h3>Roulez</h3>
        <p>Récupérez votre véhicule à Le Havre et prenez la route en toute sérénité.</p>
      </div>
    </div>
  </div>
</div>

<footer>
  <div class="logo">Auto<span style="color:var(--red)">Loc</span> Havre</div>
  <div>© 2025 AutoLoc Havre — Location de véhicules Le Havre</div>
  <div>02 35 XX XX XX</div>
</footer>

<!-- CHAT WIDGET -->
<div id="chat-widget">
  <div id="chat-box">
    <div class="chat-header">
      <div class="chat-avatar">AL</div>
      <div class="chat-header-info">
        <div class="chat-header-name">Assistant AutoLoc</div>
        <div class="chat-header-status"><div class="dot-online"></div> En ligne — disponible 24h/24</div>
      </div>
      <button class="chat-close" onclick="toggleChat()">✕</button>
    </div>
    <div class="chat-messages" id="chat-messages"></div>
    <div class="quick-replies" id="quick-replies">
      <button class="quick-reply" onclick="sendQuick('Véhicules disponibles ?')">🚗 Disponibilités</button>
      <button class="quick-reply" onclick="sendQuick('Quels sont vos tarifs ?')">💰 Tarifs</button>
      <button class="quick-reply" onclick="sendQuick('Conditions de location ?')">📋 Conditions</button>
      <button class="quick-reply" onclick="sendQuick('Comment réserver ?')">📅 Réserver</button>
    </div>
    <div class="chat-input-area">
      <input type="text" id="chat-input" placeholder="Votre question…" onkeydown="if(event.key==='Enter') sendMessage()">
      <button id="chat-send" onclick="sendMessage()">➤</button>
    </div>
  </div>
  <button id="chat-toggle" onclick="toggleChat()">
    🚗
    <div class="notif" id="toggle-notif"></div>
  </button>
</div>

<script>
const SYSTEM_PROMPT = `Tu es l'assistant virtuel d'AutoLoc Havre, une agence de location de véhicules basée à Le Havre.

Informations de l'agence :
- Adresse : Le Havre, Seine-Maritime (adresse exacte communiquée à la réservation)
- Téléphone : 02 35 XX XX XX
- Horaires : Lundi au Samedi, 8h à 19h
- Véhicules disponibles : véhicules compacts (5 places) et minibus 9 places
- Parc de 5 à 6 véhicules au total

Tarifs indicatifs :
- Compact : à partir de 35€/jour
- 9 places : à partir de 75€/jour
- Semaine : réduction de 20%
- Mois : réduction de 30%
- Kilométrage illimité inclus

Conditions de location :
- Permis de conduire valide obligatoire
- Pièce d'identité obligatoire
- Caution requise (montant selon véhicule)
- Âge minimum : 21 ans
- Assurance incluse dans le tarif de base

Réservation :
- Par téléphone au 02 35 XX XX XX
- Disponibilités à confirmer par téléphone
- Courte durée (1 jour minimum) et longue durée disponibles

Réponds toujours en français, de manière professionnelle, chaleureuse et concise. Maximum 3 phrases par réponse. Si tu ne connais pas la réponse exacte, invite le client à appeler directement.`;

let history = [];
let chatReady = false;

function toggleChat() {
  const box = document.getElementById('chat-box');
  const notif = document.getElementById('toggle-notif');
  const isOpen = box.classList.toggle('open');
  notif.style.display = 'none';
  if (isOpen && !chatReady) {
    chatReady = true;
    addMessage('bot', "Bonjour ! 👋 Bienvenue chez AutoLoc Havre. Besoin d'un véhicule ? Je suis là pour vous aider sur les tarifs, disponibilités et conditions.");
  }
}

function addMessage(role, text) {
  const container = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = `msg ${role}`;
  div.innerHTML = `
    <div class="msg-avatar-sm">${role === 'bot' ? 'AL' : 'V'}</div>
    <div class="msg-bubble">${text}</div>
  `;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function showTyping() {
  const container = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = 'msg bot';
  div.id = 'typing';
  div.innerHTML = `<div class="msg-avatar-sm">AL</div><div class="typing-indicator"><span></span><span></span><span></span></div>`;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function hideTyping() {
  const el = document.getElementById('typing');
  if (el) el.remove();
}

async function askClaude(userText) {
  history.push({ role: 'user', content: userText });
  showTyping();
  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: SYSTEM_PROMPT,
        messages: history
      })
    });
    const data = await response.json();
    const reply = data.content?.[0]?.text || "Je suis désolé, veuillez réessayer ou appeler le 02 35 XX XX XX.";
    history.push({ role: 'assistant', content: reply });
    hideTyping();
    addMessage('bot', reply);
  } catch (e) {
    hideTyping();
    addMessage('bot', "Une erreur est survenue. Appelez-nous directement au 02 35 XX XX XX.");
  }
}

function sendMessage() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';
  addMessage('user', text);
  document.getElementById('quick-replies').style.display = 'none';
  askClaude(text);
}

function sendQuick(text) {
  document.getElementById('quick-replies').style.display = 'none';
  addMessage('user', text);
  askClaude(text);
}

setTimeout(() => {
  const notif = document.getElementById('toggle-notif');
  const box = document.getElementById('chat-box');
  if (!box.classList.contains('open')) notif.style.display = 'block';
}, 3000);
</script>
</body>
</html>
